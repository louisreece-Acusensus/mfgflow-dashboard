# MFGFLOW dashboard configuration TEMPLATE
# On the Pi:  cp mfgflow.env.example mfgflow.env   then edit mfgflow.env
# NEVER commit the real mfgflow.env to git — it holds the API key and Pick List password.
PORT=8080
SMARTSHEET_KEY=PASTE-YOUR-SMARTSHEET-API-KEY-HERE
DASH_PASS=nospeeding

# Pick List server (192.168.130.145:5000) — used server-side only, to fetch
# picking % per asset. The browser never sees these credentials.
PICKLIST_BASE=http://192.168.130.145:5000
PICKLIST_FIRST=PASTE-FIRST-NAME-HERE
PICKLIST_LAST=PASTE-LAST-NAME-HERE
PICKLIST_PASS=PASTE-PASSWORD-HERE
